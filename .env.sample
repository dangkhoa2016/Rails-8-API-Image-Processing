# Rails basics
RAILS_LOG_TO_STDOUT=true
RAILS_ENV=development
PORT=4000
RAILS_MAX_THREADS=1

# CORS — comma-separated list of allowed origins
# Example: http://localhost:3000,https://app.example.com
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Image transform safety limits
# Reject resize requests that exceed these limits to avoid expensive renders.
IMAGE_MAX_RESIZE_WIDTH=4096
IMAGE_MAX_RESIZE_HEIGHT=4096
IMAGE_MAX_RESIZE_SCALE=8

# Devise mailer sender address
DEVISE_MAILER_SENDER=noreply@example.com

# JWT signing key (optional in development — falls back to secret_key_base)
# Recommended for production to allow independent key rotation.
# Generate with: bin/rails secret
# DEVISE_JWT_SECRET_KEY=

# Admin seed credentials (optional — generated randomly if not set)
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=changeme
